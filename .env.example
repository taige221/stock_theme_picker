# Theme Picker standalone runtime

# --- storage ---
DATABASE_PATH=./data/stock_analysis.db
SQLITE_WAL_ENABLED=true
SQLITE_BUSY_TIMEOUT_MS=5000

# --- theme picker history ---
THEME_PICKER_TASK_HISTORY_RETENTION_DAYS=30
THEME_PICKER_TASK_HISTORY_CLEANUP_BATCH_SIZE=200

# --- stock alert loop ---
# 单股告警后台循环开关；开启后，FastAPI 进程内会定期扫描“已到期”的规则
STOCK_ALERT_LOOP_ENABLED=false
# 后台循环基础 tick（秒），默认 60，最小 5；实际规则是否执行仍由各自 scan_interval_minutes 决定
STOCK_ALERT_LOOP_BASE_TICK_SECONDS=60

# --- theme registry / boards ---
THEME_BOARD_CACHE_TTL_SECONDS=21600
THEME_EXPANSION_QUERY_TIMEOUT=8
THEME_NEWS_QUERY_TIMEOUT=8

# --- realtime quote ---
ENABLE_REALTIME_QUOTE=true
REALTIME_SOURCE_PRIORITY=tencent,akshare_sina,efinance,akshare_em
THEME_REALTIME_SOURCE_PRIORITY=tencent,akshare_sina,efinance,akshare_em,tushare
CHIP_DISTRIBUTION_SOURCE_PRIORITY=akshare
THEME_REALTIME_QUOTE_TIMEOUT=15
THEME_TENCENT_QUOTE_TIMEOUT=15
# --- single-stock daily query ---
# 单股查询日线单源超时（秒）
STOCK_QUERY_DAILY_FETCH_TIMEOUT_SECONDS=8
# 单股查询在线日线抓取时临时禁用代理，避免本机代理误伤国内数据源
STOCK_QUERY_DAILY_UNPROXY_ENABLED=true
# 单股查询在线日线全部失败后，是否允许退回本地 stock_daily 缓存
STOCK_QUERY_ALLOW_DAILY_CACHE_FALLBACK=true
# 单股查询筹码分布超时（秒）
STOCK_QUERY_CHIP_TIMEOUT_SECONDS=2.5
# 单股查询文本情报补充超时（秒）
STOCK_QUERY_TEXT_TIMEOUT_SECONDS=2.0
# 单股查询新闻摘要补充超时（秒）
STOCK_QUERY_NEWS_TIMEOUT_SECONDS=1.8
# 单股查询基本面聚合总预算（秒）
FUNDAMENTAL_STAGE_TIMEOUT_SECONDS=25
# 单个基本面块的调用预算（秒）
FUNDAMENTAL_FETCH_TIMEOUT_SECONDS=12
ENABLE_EASTMONEY_PATCH=false
PREFETCH_REALTIME_QUOTES=true

# --- analyzer ---
BIAS_THRESHOLD=5.0

# --- llm runtime ---
# 主模型；建议填写 provider/model，例如 openai/gpt-5.5 或 deepseek/deepseek-v4-flash
LITELLM_MODEL=
# 可选：逗号分隔 fallback 模型
LITELLM_FALLBACK_MODELS=
# 可选：Agent/深度分析优先使用的模型；留空则继承 LITELLM_MODEL
AGENT_LITELLM_MODEL=
# OpenAI-compatible / AIHubMix
AIHUBMIX_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.5
# DeepSeek native
DEEPSEEK_API_KEY=

# --- deep analysis llm ---
# 启用后，单股深度分析会优先走真实 LLM 生成；失败时退回确定性分析
DEEP_ANALYSIS_LLM_ENABLED=true
# 可选：为深度分析单独指定模型；留空时继承 AGENT_LITELLM_MODEL / LITELLM_MODEL
DEEP_ANALYSIS_LITELLM_MODEL=
# 单次深度分析 LLM 请求超时（秒）
DEEP_ANALYSIS_LLM_TIMEOUT_SECONDS=45
# 单次深度分析 LLM 输出上限
DEEP_ANALYSIS_LLM_MAX_TOKENS=2200
# reasoning effort: none/minimal/low/medium/high/xhigh/default
DEEP_ANALYSIS_LLM_REASONING_EFFORT=medium
# verbosity: low/medium/high
DEEP_ANALYSIS_LLM_VERBOSITY=low

# --- search providers ---
NEWS_MAX_AGE_DAYS=3
NEWS_STRATEGY_PROFILE=short
ANSPIRE_API_KEYS=
BOCHA_API_KEYS=
MINIMAX_API_KEYS=
# Tavily 搜索 Key；支持单个 `TAVILY_API_KEY` 或逗号分隔的 `TAVILY_API_KEYS`
TAVILY_API_KEYS=
BRAVE_API_KEYS=
SERPAPI_API_KEYS=
SEARXNG_BASE_URLS=
SEARXNG_PUBLIC_INSTANCES_ENABLED=true

# --- market data providers ---
TUSHARE_TOKEN=
TICKFLOW_API_KEY=
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=
PYTDX_HOST=
PYTDX_PORT=
PYTDX_SERVERS=
