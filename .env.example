# Theme Picker standalone runtime

# --- storage ---
DATABASE_PATH=./data/stock_analysis.duckdb

# --- theme picker history ---
THEME_PICKER_TASK_HISTORY_RETENTION_DAYS=30
THEME_PICKER_TASK_HISTORY_CLEANUP_BATCH_SIZE=200

# --- stock alert loop ---
# 单股告警后台循环开关；开启后，FastAPI 进程内会定期扫描“已到期”的规则
STOCK_ALERT_LOOP_ENABLED=false
# 后台循环基础 tick（秒），默认 60，最小 5；实际规则是否执行仍由各自 scan_interval_minutes 决定
STOCK_ALERT_LOOP_BASE_TICK_SECONDS=60
# 信息观察池后台循环开关
INFORMATION_WATCH_LOOP_ENABLED=false
# 信息观察池后台循环基础 tick（秒）
INFORMATION_WATCH_LOOP_BASE_TICK_SECONDS=300
# 信息观察池扫描间隔（分钟）
INFORMATION_WATCH_SCAN_INTERVAL_MINUTES=60
# 信息观察池单次搜索超时（秒）
INFORMATION_WATCH_QUERY_TIMEOUT_SECONDS=8
# 是否启用一级硬源直连（巨潮公告）
INFORMATION_L1_DIRECT_ENABLED=true
# 一级硬源直连单次请求超时（秒）
INFORMATION_L1_DIRECT_TIMEOUT_SECONDS=10
# 开放发现池开关；开启后会并行扫描“订单/扩产/涨价/政策/量产”等全局高价值事件模板
OPEN_DISCOVERY_POOL_ENABLED=false
# 开放发现池扫描间隔（分钟）
OPEN_DISCOVERY_SCAN_INTERVAL_MINUTES=120
# 信息事件晋升到主题因子扫描的 freshness 阈值
INFORMATION_EVENT_MIN_FRESHNESS_SCORE=70
# 信息事件晋升到主题因子扫描的 credibility 阈值
INFORMATION_EVENT_MIN_CREDIBILITY_SCORE=65
# 高质量信息事件出现后是否自动触发主题因子扫描
THEME_FACTOR_SCAN_AUTO_ENABLED=false

# --- theme registry / boards ---
THEME_BOARD_CACHE_TTL_SECONDS=21600
THEME_EXPANSION_QUERY_TIMEOUT=8
THEME_NEWS_QUERY_TIMEOUT=8

# --- realtime quote ---
ENABLE_REALTIME_QUOTE=true
# 留空使用默认顺序；配置 Tushare key 后默认前置 tushare。显式填写时按填写顺序执行。
REALTIME_SOURCE_PRIORITY=
THEME_REALTIME_SOURCE_PRIORITY=
DAILY_BAR_SOURCE_PRIORITY=
CHIP_DISTRIBUTION_SOURCE_PRIORITY=
THEME_REALTIME_QUOTE_TIMEOUT=15
THEME_TENCENT_QUOTE_TIMEOUT=15
# --- single-stock daily query ---
# 单股查询日线单源超时（秒）
STOCK_QUERY_DAILY_FETCH_TIMEOUT_SECONDS=8
# 单股查询在线日线抓取时临时禁用代理，避免本机代理误伤国内数据源
STOCK_QUERY_DAILY_UNPROXY_ENABLED=true
# 单股查询在线日线全部失败后，是否允许退回本地 stock_daily 缓存
STOCK_QUERY_ALLOW_DAILY_CACHE_FALLBACK=true
# 单股查询筹码分布超时（秒）
STOCK_QUERY_CHIP_TIMEOUT_SECONDS=2.5
# 单股查询文本情报补充超时（秒）
STOCK_QUERY_TEXT_TIMEOUT_SECONDS=10
# 单股查询新闻摘要补充超时（秒）
STOCK_QUERY_NEWS_TIMEOUT_SECONDS=10
# ETF 日K抓取超时（秒）
ETF_DAILY_BAR_TIMEOUT_SECONDS=8
# ETF 实时行情抓取超时（秒）
ETF_REALTIME_QUOTE_TIMEOUT_SECONDS=8
# 观察池规则扫描的单股实时行情超时（秒）
WATCHLIST_REALTIME_QUOTE_TIMEOUT_SECONDS=8
# ETF mootdx 盘口抓取超时（秒）
ETF_MOOTDX_QUOTE_TIMEOUT_SECONDS=8
# ETF 重仓股抓取超时（秒）
ETF_TOP_HOLDINGS_TIMEOUT_SECONDS=12
# ETF 日频指标抓取超时（秒）
ETF_DAILY_METRICS_TIMEOUT_SECONDS=12
# ETF estimated IOPV 估算超时（秒）
ETF_ESTIMATED_IOPV_TIMEOUT_SECONDS=8
# 单股查询基本面聚合总预算（秒）
FUNDAMENTAL_STAGE_TIMEOUT_SECONDS=25
# 单个基本面块的调用预算（秒）
FUNDAMENTAL_FETCH_TIMEOUT_SECONDS=12
ENABLE_EASTMONEY_PATCH=false
PREFETCH_REALTIME_QUOTES=true

# --- analyzer ---
BIAS_THRESHOLD=5.0

# --- llm runtime ---
# 主模型；建议填写 provider/model，例如 openai/gpt-5.5 或 deepseek/deepseek-v4-flash
LITELLM_MODEL=
# 可选：逗号分隔 fallback 模型
LITELLM_FALLBACK_MODELS=
# 可选：Agent/深度分析优先使用的模型；留空则继承 LITELLM_MODEL
AGENT_LITELLM_MODEL=
# OpenAI-compatible / AIHubMix
AIHUBMIX_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.5
# DeepSeek native
DEEPSEEK_API_KEY=

# --- deep analysis llm ---
# 启用后，单股深度分析会优先走真实 LLM 生成；失败时退回确定性分析
DEEP_ANALYSIS_LLM_ENABLED=true
# 可选：为深度分析单独指定模型；留空时继承 AGENT_LITELLM_MODEL / LITELLM_MODEL
DEEP_ANALYSIS_LITELLM_MODEL=
# 单次深度分析 LLM 请求超时（秒）
DEEP_ANALYSIS_LLM_TIMEOUT_SECONDS=45
# 单次深度分析 LLM 输出上限
DEEP_ANALYSIS_LLM_MAX_TOKENS=2200
# reasoning effort: none/minimal/low/medium/high/xhigh/default
DEEP_ANALYSIS_LLM_REASONING_EFFORT=medium
# verbosity: low/medium/high
DEEP_ANALYSIS_LLM_VERBOSITY=low

# --- search providers ---
NEWS_MAX_AGE_DAYS=3
NEWS_STRATEGY_PROFILE=short
ANSPIRE_API_KEYS=
BOCHA_API_KEYS=
MINIMAX_API_KEYS=
# Tavily 搜索 Key；支持单个 `TAVILY_API_KEY` 或逗号分隔的 `TAVILY_API_KEYS`
TAVILY_API_KEYS=
BRAVE_API_KEYS=
# SerpApi 搜索 Key；支持单个 `SERPAPI_API_KEY` 或逗号分隔的 `SERPAPI_API_KEYS`
SERPAPI_API_KEY=
SERPAPI_API_KEYS=
SEARXNG_BASE_URLS=
SEARXNG_PUBLIC_INSTANCES_ENABLED=true

# --- market data providers ---
TUSHARE_TOKEN=
TICKFLOW_API_KEY=
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=
PYTDX_HOST=
PYTDX_PORT=
PYTDX_SERVERS=
